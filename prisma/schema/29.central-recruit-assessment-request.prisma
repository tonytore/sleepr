model CentralRecruitAssessmentRequest {
  id            String @id @default(ulid())
  subject       String @db.VarChar(500)
  description   String @db.Text
  userId        String
  currentStepId String @unique

  user        User                      @relation(fields: [userId], references: [id])
  currentStep CentralRecruitRequestStep @relation(fields: [currentStepId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  centralRecruitRequests CentralRecruitRequest[]

  @@map("central_recruit_assessment_requests")
}
