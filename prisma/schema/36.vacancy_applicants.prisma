model VacancyApplicant {
  id                        String   @id @default(ulid())
  isSelected                Boolean?
  vacancyId                 String
  centralRecruitRequestId   String
  vacancyCandidateProfileId String

  vacancy Vacancy                 @relation(fields: [vacancyId], references: [id])
  request CentralRecruitRequest   @relation(fields: [centralRecruitRequestId], references: [id])
  profile VacancyCandidateProfile @relation(fields: [vacancyCandidateProfileId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("vacancy_applicants")
}
