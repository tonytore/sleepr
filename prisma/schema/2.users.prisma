model User {
  id                     String    @id @default(ulid()) @db.Char(26)
  firstName              String    @db.VarChar(128)
  middleName             String    @db.VarChar(128)
  lastName               String    @db.VarChar(128)
  email                  String    @unique @db.VarChar(128)
  phoneNumber            String    @unique @db.VarChar(128)
  dob                    DateTime  @db.Date
  gender                 Gender
  isOnline               Boolean   @default(false)
  emailVerifiedAt        DateTime?
  password               String    @db.Text
  rememberToken          String?   @db.Text
  lockOutUntil           DateTime?
  failedLoginAttempts    Int       @default(0)
  isActive               Boolean   @default(true)
  twoFactorSecret        String?   @db.Text
  twoFactorRecoveryCodes String?   @db.Text
  twoFactorConfirmedAt   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  refreshTokens                    RefreshToken[]
  roles                            UserRole[]
  assessmentRequests               AssessmentRequest[]
  centralRecruitAssessmentRequests CentralRecruitAssessmentRequest[]
  requestSteps                     RequestStep[]
  centralRecruitRequestSteps       CentralRecruitRequestStep[]
  requestCandidates                RequestCandidate[]
  agencyCandidates                 AgencyCandidate[]                 @relation("agencyCandidate")
  agencies                         AgencyCandidate[]                 @relation("agency")
  vacancyProfiles                  VacancyCandidateProfile[]
  thirdParties                     CompetencyAssessmentThirdParty[]
  thirdPartyAssessmentSchedules    ThirdPartyAssessmentSchedule[]
  questionSubmitters               QuestionSubmitter[]
  questionReviewers                QuestionReviewer[]
  reservations                     Reservation[]

  @@map("users")
}

enum Gender {
  male
  female
}
