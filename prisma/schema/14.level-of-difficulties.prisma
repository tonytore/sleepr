model LevelOfDifficulty {
  id          String  @id @default(ulid())
  name        String  @unique @db.VarChar(255)
  description String? @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  questions                                                Question[]
  questionEntryScheduleTypeOfCompetencyLevelOfDifficulties QuestionEntryScheduleTypeOfCompetencyLevelOfDifficulty[]

  @@map("level_of_difficulties")
}
