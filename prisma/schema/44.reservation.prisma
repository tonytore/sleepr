model Reservation {
  id        String   @id @default(ulid())
  startDate DateTime
  endDate   DateTime
  placeId   String
  invoiceId String
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("reservations")
}
