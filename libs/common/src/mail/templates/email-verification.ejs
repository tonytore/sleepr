<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify Your Email Address</title>
    <style>
      body {
        font-family:
          'Inter',
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          Roboto,
          sans-serif;
        background-color: #f4f7f9;
        margin: 0;
        padding: 0;
        -webkit-font-smoothing: antialiased;
      }
      .wrapper {
        width: 100%;
        table-layout: fixed;
        background-color: #f4f7f9;
        padding-bottom: 40px;
      }
      .main {
        background-color: #ffffff;
        margin: 40px auto;
        width: 100%;
        max-width: 600px;
        border-spacing: 0;
        color: #2d3748;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
      }
      .header {
        background-color: #38a169;
        padding: 40px 0;
        text-align: center;
      }
      .header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      .content {
        padding: 48px 40px;
      }
      .content h2 {
        margin-top: 0;
        font-size: 22px;
        font-weight: 700;
        color: #1a202c;
      }
      .content p {
        font-size: 16px;
        line-height: 1.6;
        color: #4a5568;
        margin-bottom: 24px;
      }
      .button-container {
        text-align: center;
        margin: 32px 0;
      }
      .button {
        background-color: #38a169;
        color: #ffffff;
        padding: 14px 32px;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 600;
        font-size: 16px;
        display: inline-block;
      }
      .footer {
        background-color: #f7fafc;
        padding: 32px 40px;
        text-align: center;
        font-size: 14px;
        color: #718096;
        border-top: 1px solid #edf2f7;
      }
      .footer p {
        margin: 8px 0;
      }
      .security-note {
        font-size: 14px;
        color: #a0aec0;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div
        style="
          display: none;
          max-height: 0;
          max-width: 0;
          opacity: 0;
          overflow: hidden;
          mso-hide: all;
          font-family: sans-serif;
        "
      >
        Please verify your email address to complete your PSCMS account setup
        and access all features.
      </div>
      <table class="main">
        <tr>
          <td class="header">
            <h1>PSCMS</h1>
          </td>
        </tr>
        <tr>
          <td class="content">
            <h2>Verify Your Email Address</h2>
            <p>Hello <%= name %>,</p>
            <p>
              Thank you for signing up for PSCMS! To ensure the security of your
              account and gain full access to our platform, please verify your
              email address linked to <strong><%= email %></strong>.
            </p>
            <p>
              Click the button below to confirm your email. This link will be
              active for 24 hours.
            </p>
            <div class="button-container">
              <a href="<%= url %>" class="button">Verify Email Address</a>
            </div>
            <p>
              If you didn't create an account with us, you can safely ignore
              this email.
            </p>
            <p class="security-note">
              For your security, never share this link with anyone.
            </p>
          </td>
        </tr>
        <tr>
          <td class="footer">
            <p>Thank you for choosing PSCMS.</p>
            <p>&copy; 2026 PSCMS Support Team. All rights reserved.</p>
          </td>
        </tr>
      </table>
    </div>
  </body>
</html>
